generator client {
    provider             = "prisma-client-py"
    interface            = "asyncio"
    recursive_type_depth = "5"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// BEGIN SECURITY ===============================>
enum METHODS {
    POST
    GET
    DELETE
    PATCH
}

model Role {
    id         String @id @default(uuid())
    name       String
    identifier String @unique
    idSector   String
    Sector     Sector @relation(fields: [idSector], references: [id])
    User       User[]

    Route Route[]

    @@unique([id, idSector])
}

model Route {
    id     String  @id @default(uuid())
    path   String
    method METHODS @default(GET)
    roles  Role[]

    Routers Routers[]
}

model Sector {
    id   String @id @default(uuid())
    name String @unique
    Role Role[]
    User User[]
}

model User {
    id            String          @id @default(uuid())
    email         String          @unique
    name          String
    description   String?
    password      String
    profileImage  String?
    phoneNumber   String?
    status        Boolean         @default(true)
    idSector      String
    createdAt     DateTime        @default(now())
    idRole        String
    Role          Role            @relation(fields: [idRole, idSector], references: [id, idSector])
    Sector        Sector          @relation(fields: [idSector], references: [id])
    Notifications Notifications[]
    Solicitations Solicitations[]
    alerts        Alerts[]
}

model Notifications {
    id      String  @id @default(uuid())
    message String
    read    Boolean
    users   User[]
}

enum SolicitationStatus {
    QUEUED
    IN_PROGRESS
    CONCLUED
}

model Solicitations {
    id        String             @id @default(uuid())
    event     String
    createdAt DateTime           @default(now())
    status    SolicitationStatus
    userId    String
    user      User               @relation(fields: [userId], references: [id])
    hash      String             @unique
}

// END SECURITY ===============================>
// BEGIN SERVICES ===============================>

model Services {
    id          String       @id @default(uuid()) @db.Uuid
    name        String
    description String       @default("")
    module      String
    entryPoint  String
    parameters  Parameters[]
    active      Boolean      @default(true)
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    Routers Routers[]

    Controllers Controllers[]
}

model Routers {
    id            String       @id @default(uuid()) @db.Uuid
    name          String
    description   String       @default("")
    module        String
    entryPoint    String
    endpoint      String       @unique
    active        Boolean      @default(true)
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt
    services      Services[]
    Routes        Route[]
    Controllers   Controllers? @relation(fields: [controllersId], references: [id])
    controllersId String?      @db.Uuid
}

model Controllers {
    id          String     @id @default(uuid()) @db.Uuid
    name        String
    description String     @default("")
    module      String
    entryPoint  String
    active      Boolean    @default(true)
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    services    Services[]
    routers     Routers[]
}

model Parameters {
    id          String   @id @default(uuid()) @db.Uuid
    name        String
    description String   @default("")
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    Services Services[]

    integrations   Integrations[]
}

// END SERVICES ===============================>


// BEGIN WORKERS ===============================>
model Workers {
    id          String   @id @default(uuid()) @db.Uuid
    name        String
    description String   @default("")
    event       String
    module      String
    entryPoint  String
    update_rate Int      @default(0) // Em segundos, 0 para manual
    dbName      String? // Para armazenar o nome do banco de dados, se necessário
    beginDate   String? // Para armazenar a data de início, se necessário
    endDate     String? // Para armazenar a data de término, se necessário
    createdAt   DateTime @default(now())
    updatedAt   DateTime @default(now())
    alerts      Alerts[]
}

// END WORKERS ===============================>

// BEGIN INTEGRATIONS ========================>

model Integrations {
    id              String           @id @default(uuid())
    name            String           @unique
    description     String
    active          Boolean
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    entrypoint      String
    module          String
    preferenceOrder Int              @default(0)
    type            IntegrationsType @default(OTHERS)
    parameters      Parameters[]
}

enum IntegrationsType {
    OTHERS
    PAYMENTS
    VIDEOS
    HOOKS
}

//END INTEGRATIONS ===========================>

// BEGIN MONITORING ===============================>
model Alerts {
    id           String     @id @default(uuid()) @db.Uuid
    name         String
    description  String     @default("")
    active       Boolean    @default(true)
    event        String //evento que o alerta envia, pode ser um nome de evento ou uma categoria
    type         AlertTypes @relation(fields: [alertTypesId], references: [id]) //tipo do alerta, pode ser usado para categorizar os alertas e definir comportamentos específicos para cada tipo
    message      String //mensagem personalizada que será enviada quando o alerta for acionado
    senderId     String?    @db.Uuid // Para armazenar a relação com o remetente, se necessário
    Senders      Senders?   @relation(fields: [senderId], references: [id])
    workerId     String?    @db.Uuid // Para armazenar a relação com o worker, se necessário
    Workers      Workers?   @relation(fields: [workerId], references: [id])
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @default(now())
    condition    Json? // Para armazenar condições específicas para o alerta, como thresholds, filtros, etc.
    target       User[] // Para armazenar os usuários que receberão o alerta, se necessário
    alertTypesId String     @db.Uuid
}

model AlertTypes {
    id         String   @id @default(uuid()) @db.Uuid
    name       String
    entryPoint String
    module     String
    alerts     Alerts[]
}

model Senders {
    id          String      @id @default(uuid()) @db.Uuid
    name        String
    description String      @default("")
    type        SenderTypes //tipo do remetente, pode ser usado para categorizar os remetentes e definir comportamentos específicos para cada tipo
    config      Json //configurações específicas do remetente, como credenciais de API, número de telefone, etc.

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
    alerts    Alerts[]
}

enum SenderTypes {
    EMAIL
    SMS
    PUSH_NOTIFICATION
    WHATSAPP_UNOFFICIAL
    API
}

// END MONITORING ===============================>
